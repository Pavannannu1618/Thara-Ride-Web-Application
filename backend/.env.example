# ── App ──
NODE_ENV=development
PORT=5000
CLIENT_URLS=http://localhost:3000,http://localhost:3001,https://thara-ride-web-application.vercel.app


# ── Database ──
MONGODB_URI=mongodb://localhost:27017/thararide
REDIS_URL=redis://localhost:6379

# ── Auth ──
JWT_SECRET=your-256-bit-random-secret-here
JWT_REFRESH_SECRET=another-256-bit-secret-here
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ── Maps ──
GOOGLE_MAPS_API_KEY=AIzaYourKeyHere

# ── Payments ──
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# ── Notifications ──
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE=+14155552671
SENDGRID_API_KEY=SG.xxx
FIREBASE_SERVICE_ACCOUNT_JSON={}

# ── AWS ──
AWS_REGION=ap-south-1
AWS_S3_BUCKET=thararide-kyc
AWS_ACCESS_KEY_ID=AKIAxxx
AWS_SECRET_ACCESS_KEY=xxx